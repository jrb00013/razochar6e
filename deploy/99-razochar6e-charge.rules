# Allow razochar6e to write charge thresholds without root (adjust BAT* if needed).
# Install: sudo cp deploy/99-razochar6e-charge.rules /etc/udev/rules.d/ && sudo udevadm control --reload
SUBSYSTEM=="power_supply", ATTR{type}=="Battery", ATTR{charge_control_end_threshold}=="*", MODE="0664", GROUP="plugdev"
